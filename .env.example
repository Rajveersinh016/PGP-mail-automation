# ============================================================
# PGP Container Glass Intelligence Platform — Environment Variables
# ============================================================
# Copy this file to .env for local development
# For GitHub Actions: add these as Repository Secrets
# ============================================================

# Gmail sender account (must have 2FA enabled)
GMAIL_USER=your_gmail_sender@gmail.com

# Gmail App Password (NOT your regular password)
# How to get: Google Account → Security → 2-Step Verification → App Passwords
# Generate one for "Mail" on "Windows Computer"
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Comma-separated list of email recipients
# Example: john@company.com,jane@company.com,reports@pgpglass.com
RECIPIENTS=recipient1@example.com,recipient2@example.com

# Gemini 2.5 Flash API Key (REQUIRED for AI relevance filtering and summarization)
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
